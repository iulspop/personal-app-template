    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@tabler/icons-react": "^3.44.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
