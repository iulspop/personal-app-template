    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@faker-js/faker": "^10.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "7.15.1",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "happy-dom": "^20.9.0",
    "lefthook": "^2.1.6",
    "prisma": "^7.8.0",
    "react-router-auto-routes": "^0.8.4",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "name": "personal-app-template",
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "lefthook",
      "prisma"
    ]
  },
  "private": true,
  "scripts": {
    "build": "prisma generate && react-router build",
    "check": "biome check --write .",
    "db:migrate": "prisma migrate dev --name",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && prisma db push && pnpm db:seed",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "dev": "react-router dev",
    "lint": "biome ci --css-parse-tailwind-directives=true .",
    "prepare": "lefthook install",
    "start": "react-router-serve ./build/server/index.js",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "storybook:build": "STORYBOOK=true storybook build",
    "test": "vitest --reporter=verbose --run",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:watch": "vitest --reporter=verbose",
    "typecheck": "prisma generate && react-router typegen && tsc"
  },
  "type": "module"
}
